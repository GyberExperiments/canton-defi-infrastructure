# 🔐 Example Secrets Configuration
# НИКОГДА не коммитьте этот файл с реальными значениями!
# Скопируйте как .secrets и заполните реальными данными

# Admin Configuration
ADMIN_EMAIL=admin@canton-otc.com
ADMIN_PASSWORD=your_secure_password_here
ADMIN_NAME=Admin

# GitHub Configuration (для скриптов)
GITHUB_TOKEN=ghp_your_github_token_here

# Kubernetes Configuration
KUBECONFIG_PATH=~/.kube/config

# Примечания:
# - Используйте сильные пароли (минимум 16 символов)
# - Никогда не отправляйте .secrets файл в Git
# - Добавьте .secrets в .gitignore

