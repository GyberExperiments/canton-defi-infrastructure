# ====================================
# Canton OTC Exchange Environment Variables
# ====================================

# ====================================
# Google Sheets Integration
# ====================================
# Sheet ID from URL: https://docs.google.com/spreadsheets/d/{SHEET_ID}/edit
GOOGLE_SHEET_ID=your_google_sheet_id_here

# Service account email from Google Cloud Console
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com

# Service account private key (keep the quotes and newlines)
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour_Private_Key_Here\n-----END PRIVATE KEY-----\n"

# Sheet name (default: Orders)
GOOGLE_SHEET_NAME=Orders

# ====================================
# Telegram Bot Integration
# ====================================
# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=1234567890:ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghi

# Chat ID where notifications will be sent (group or channel)
TELEGRAM_CHAT_ID=-1001234567890

# ====================================
# Email Service Configuration
# ====================================
# SMTP server hostname
EMAIL_HOST=smtp.gmail.com

# SMTP port (587 for TLS, 465 for SSL)
EMAIL_PORT=587

# Use SSL/TLS (true/false)
EMAIL_SECURE=false

# SMTP username (usually your email)
EMAIL_USER=your-email@gmail.com

# SMTP password (for Gmail use App Password, not regular password)
EMAIL_PASSWORD=your-app-password-here

# From address for sent emails
EMAIL_FROM_ADDRESS=support@canton-otc.com

# From name for sent emails
EMAIL_FROM_NAME=Canton OTC Exchange

# ====================================
# Security & Admin
# ====================================
# Admin API key for protected endpoints (generate a strong random key)
ADMIN_API_KEY=generate-a-very-long-random-secure-key-here

# ====================================
# Application Configuration
# ====================================
# Environment (development/production)
NODE_ENV=development

# Public app URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ====================================
# Payment Token Receiving Addresses
# ====================================
# Ethereum network receiving address (for ETH and ERC-20 tokens)
ETH_RECEIVING_ADDRESS=0xYourEthereumAddressHere

# BSC network receiving address (for BNB and BEP-20 tokens)
BSC_RECEIVING_ADDRESS=0xYourBSCAddressHere

# TRON network receiving address (for TRX and TRC-20 tokens)
TRON_RECEIVING_ADDRESS=TYourTronAddressHere

# Canton Coin price in USD
CANTON_COIN_PRICE_USD=0.20
